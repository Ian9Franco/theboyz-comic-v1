            { "text": "—Sofi llegó bien.", "size": "small", "posX": 60, "posY": 50, "tailX": 35, "tailY": 40, "tailWidth": 6, "tailCurvature": -22, "width": 120, "fontSize": 9, "borderRadius": 18 },
            { "text": "—Todavía no puedo creer que se haya querido quedar en este universo. Estaba decidida a conocer la Tierra antes de... ya sabés. De que no quede nada.", "size": "small", "posX": 0, "posY": 40, "tailX": 40, "tailY": 45, "tailWidth": 6, "tailCurvature": -22, "width": 120, "fontSize": 9, "borderRadius": 18 }
          ]
        },
        {
          "focusY": 0.6,
          "dialogue": [
            { "text": "—Sofi está bien,. Se Salvó y ahora se va a comer sushi al otro lado del charco. ", "size": "small", "posX": 85, "posY": 60, "tailX": 55, "tailY": 60, "tailWidth": 6, "tailCurvature": -22, "width": 120, "fontSize": 9, "borderRadius": 18 },
            { "text": "Dejen de maquinar, boludos, que nos salió redonda.", "size": "small", "posX": 15, "posY": 60, "tailX": 40, "tailY": 65, "tailWidth": 12, "tailCurvature": 44, "width": 120, "fontSize": 9, "borderRadius": 18 }
          ]
        },
        {
          "focusY": 0.8,
