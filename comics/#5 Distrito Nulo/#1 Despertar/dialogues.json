            { "text": "—¡Ah...! Mierda, me pegó un calorazo de golpe... Siento que me quemo por dentro, boludo.", "speaker": "Uandi", "size": "small", "posX": 70, "posY": 95, "tailX": 70, "tailY": 75, "tailWidth": 6, "tailCurvature": -22, "width": 120, "fontSize": 9, "borderRadius": 18, "fontFamily": "bungee" },
            { "text": "—¡Uandi! Bancá un poco, ya estamos a unas cuadras. Aguantá.", "size": "small", "posX": 45, "posY": 100, "tailX": 50, "tailY": 85, "tailWidth": 6, "tailCurvature": -22, "width": 120, "fontSize": 9, "borderRadius": 18 },
            { "text": "Este pelotudo no tiene ni obra social", "size": "small", "posX": 0, "posY": 90, "tailX": 10, "tailY": 85, "tailWidth": 6, "tailCurvature": -22, "width": 120, "fontSize": 9, "borderRadius": 18 }
          ],
