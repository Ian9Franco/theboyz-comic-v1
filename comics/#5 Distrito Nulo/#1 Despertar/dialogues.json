            { "text": "—Vení, sentate en el living. Te voy a conectar los sensores para medir qué carajo está pasando con tu temperatura.", "size": "small", "posX": 75, "posY": 85, "tailX": 45, "tailY": 85, "tailWidth": 6, "tailCurvature": -22, "width": 120, "fontSize": 9, "borderRadius": 18 }
