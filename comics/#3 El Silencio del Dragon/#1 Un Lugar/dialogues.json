          "focusY": 0.87,
          "dialogue": [
            { "text": "Tomá un pedazo de pan, Mati.", "size": "small", "posX": 85, "posY": 80, "tailX": 70, "tailY": 80, "tailWidth": 6, "tailCurvature": -22, "width": 120, "fontSize": 9, "borderRadius": 18 },
