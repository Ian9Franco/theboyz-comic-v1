    "16": {
      "panels": [
        {
          "focusY": 0.13,
          "dialogue": [
            { "text": "Te sirvo, Juli? Decime si querés más que hay de sobra en la olla.", "size": "small", "posX": 50, "posY": 0, "tailX": 25, "tailY": 10, "tailWidth": 6, "tailCurvature": -22, "width": 120, "fontSize": 9, "borderRadius": 18 },
            { "text": "Jajaja, te agradezco, gordo. El hambre que tengo es directamente proporcional al quilombo que es este taller.", "size": "small", "posX": 90, "posY": 5, "tailX": 70, "tailY": 10, "tailWidth": 6, "tailCurvature": -22, "width": 120, "fontSize": 9, "borderRadius": 18 }
          ]
        },
        {
          "focusY": 0.36,
          "dialogue": [
