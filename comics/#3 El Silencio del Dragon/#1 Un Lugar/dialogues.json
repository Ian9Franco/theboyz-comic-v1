            { "text": "¡Salud!", "size": "small", "posX": 80, "posY": 50, "tailX": 80, "tailY": 60, "tailWidth": 6, "tailCurvature": -22, "width": 120, "fontSize": 9, "borderRadius": 18 }
          ]
        },
        {
          "focusY": 0.89,
          "dialogue": [
            { "text": "...Y ahí la vimos, che. En el medio del caos de Los Ángeles, congelada en la ventana de ese hotel mientras todo se pixelaba.", "size": "small", "posX": 85, "posY": 70, "tailX": 70, "tailY": 80, "tailWidth": 6, "tailCurvature": -22, "width": 120, "fontSize": 8, "borderRadius": 18 },
