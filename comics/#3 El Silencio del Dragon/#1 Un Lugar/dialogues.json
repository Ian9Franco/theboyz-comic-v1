            { "text": "¡¿Qué droga boludo?!", "size": "small", "posX": 70, "posY": 45, "tailX": 75, "tailY": 25, "tailWidth": 6, "tailCurvature": -22, "width": 120, "fontSize": 9, "borderRadius": 18 },
