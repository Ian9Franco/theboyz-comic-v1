    "17": {
      "panels": [
        {
          "dialogue": [
            { "text": "No, boludo, pero no entienden la demencia. Cuando nos metimos en la selva, la escotilla en el suelo estaba tapada de mugre.", "size": "small", "posX": 65, "posY": 0, "tailX": 55, "tailY": 10, "tailWidth": 6, "tailCurvature": -22, "width": 175, "fontSize": 8, "borderRadius": 18 },
            { "text": "Ni bien bajamos, se nos aparecieron tres milicos corruptos de atrás de una columna con las escopetas en la mano. Yo me quedé duro.", "size": "small", "posX": 30, "posY": 0, "tailX": 55, "tailY": 10, "tailWidth": 6, "tailCurvature": -22, "width": 175, "fontSize": 8, "borderRadius": 18 },
