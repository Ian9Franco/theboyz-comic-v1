            { "text": "Gracias por recibirme así... posta que me hacían falta unos minutos de tranquilidad.", "size": "small", "posX": 5, "posY": 50, "tailX": 20, "tailY": 65, "tailWidth": 16, "tailCurvature": 100, "width": 120, "fontSize": 8, "borderRadius": 18 },
