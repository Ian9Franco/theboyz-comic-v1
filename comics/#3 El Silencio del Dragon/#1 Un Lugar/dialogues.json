          ],
          "focusY": 0.16
        },
        {
          "focusY": 0.36,
          "dialogue": [
            { "text": "¡¿Qué tres milicos?! ¡Eran como veinte! ¡A mano limpia me los tuve que papear mientras este histriónico gritaba atrás mío!", "size": "small", "posX": 50, "posY": 25, "tailX": 60, "tailY": 35, "tailWidth": 16, "tailCurvature": -22, "width": 120, "fontSize": 8, "borderRadius": 18 },
            { "text": "¡¿Y qué querías que haga si nos tiraban a pegar?! ¡Casi salimos de ahí en una bolsa de consorcio!", "size": "small", "posX": 5, "posY": 25, "tailX": 10, "tailY": 35, "tailWidth": 6, "tailCurvature": -22, "width": 120, "fontSize": 8, "borderRadius": 18 },
            { "text": "Jajaja, ¡ay por favor! ¡Hubiera dado mi maletín de fichas por ver a Ian corriendo entre los árboles!", "size": "small", "posX": 80, "posY": 25, "tailX": 80, "tailY": 35, "tailWidth": 6, "tailCurvature": -22, "width": 120, "fontSize": 8, "borderRadius": 18 }
          ]
        },
        {
          "focusY": 0.6,
          "dialogue": [
            { "text": "¡¡¡CHIN-CHIN!!!", "style": "caption", "size": "small", "posX": 50, "posY": 70, "tailX": 50, "tailY": 65, "tailWidth": 6, "tailCurvature": -22, "width": 120, "fontSize": 9, "borderRadius": 18, "customBg": "#f5e642", "customColor": "#000000" },
            { "text": "¡Bueno, che, un brindis! Por el gordo que cocina bien y por estar todos vivos de pedo.", "size": "small", "posX": 30, "posY": 45, "tailX": 40, "tailY": 55, "tailWidth": 6, "tailCurvature": -22, "width": 135, "fontSize": 8, "borderRadius": 18 },
